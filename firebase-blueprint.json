{
  "entities": {
    "User": {
      "title": "Profil Pengguna",
      "description": "Profil pengguna yang berisi status keanggotaan dan batas akses harian.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "membership": { "type": "string", "enum": ["free", "premium"] },
        "dailyAccessCount": { "type": "integer", "description": "Jumlah sinyal yang dilihat hari ini." },
        "lastAccessDate": { "type": "string", "format": "date", "description": "Tanggal terakhir pengguna mengakses sinyal (YYYY-MM-DD)." },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "push": { "type": "boolean" }
          }
        },
        "metaTrader": {
          "type": "object",
          "properties": {
            "token": { "type": "string", "description": "MetaApi Token" },
            "accountId": { "type": "string", "description": "MetaApi Account ID" },
            "status": { "type": "string", "enum": ["connected", "disconnected", "error"] }
          }
        }
      },
      "required": ["uid", "email", "role", "membership"]
    },
    "Signal": {
      "title": "Sinyal Trading",
      "description": "Sinyal trading untuk XAU atau BTC.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pair": { "type": "string", "enum": ["XAU/USD", "BTC/USD"] },
        "action": { "type": "string", "enum": ["BUY", "SELL"] },
        "entryPrice": { "type": "number" },
        "tp": { "type": "number" },
        "sl": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "result": { "type": "number", "description": "Profit/Loss dalam pips atau poin." },
        "createdAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "analysis": { "type": "string", "description": "Analisis pasar real-time." }
      },
      "required": ["pair", "action", "entryPrice", "tp", "sl", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Dokumen profil pengguna."
    },
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Koleksi sinyal trading."
    }
  }
}
